anchor=top-right
width=360
height=120
padding=16
border-size=1
border-radius=14
background-color=#0f1417cc
border-color=#8a929740
text-color=#dfe3e7
progress-color=over #8ecff240
font=JetBrainsMono Nerd Font 11
default-timeout=5000
ignore-timeout=0
max-visible=5
sort=-time
icon-path=/usr/share/icons/Papirus-Dark
max-icon-size=48

[urgency=low]
background-color=#0f1417bb
border-color=#8a929725
text-color=#c0c7cd
default-timeout=3000

[urgency=normal]
background-color=#0f1417cc
border-color=#8a929740
text-color=#dfe3e7
default-timeout=5000

[urgency=critical]
background-color=#93000acc
border-color=#ffb4ab60
text-color=#ffdad6
default-timeout=0
