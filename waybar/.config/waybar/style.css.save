* {
    border: none;
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 12px;
    min-height: 0;
    padding: 0;
    margin: 0;
}

window#waybar {
    background: transparent;
}

#workspaces {
    background: rgba(26, 27, 38, 0.88);
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 2px 6px;
    margin-left: 8px;
}

#workspaces button {
    padding: 0 8px;
    color: #565f89;
    background: transparent;
    border-radius: 10px;
    font-size: 14px;
}

#workspaces button.active {
    color: #ffffff;
    background: rgba(122, 162, 247, 0.4);
}

#workspaces button:hover {
    background: rgba(90, 95, 137, 0.3);
}

#window {
    background: rgba(26, 27, 38, 0.88);
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 2px 16px;
    margin-left: 2px;
    color: #a9b1d6;
    font-size:;
    padding: 0 14px;
    color: #7aa2f7;
    font-weight: bold;
    font-size: 14px;
    letter-spacing: 0px;
}


.modules-right {
    background: rgba(26, 27, 38, 0.88);
    border-radius: 14px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 2px 10px;
    margin-right: 8px;
}

#temperature { color: #e0af68; padding: 0 8px; }
#cpu         { color: #bb9af7; padding: 0 8px; }
#memory      { color: #73daca; padding: 0 8px; }
#pulseaudio  { color: #7aa2f7; padding: 0 8px; }
#backlight   { color: #e0af68; padding: 0 8px; }
#battery     { color: #9ece6a; padding: 0 8px; }
#tray        { padding: 0 8px; }

#battery.warning  { color: #e0af68; }
#battery.critical { color: #f7768e; }
